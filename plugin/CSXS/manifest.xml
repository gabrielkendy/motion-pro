<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   ExtensionBundleId="com.motionvault.panel"
                   ExtensionBundleVersion="2.0.0"
                   ExtensionBundleName="Motion Titles"
                   Version="5.0">
    <ExtensionList>
        <Extension Id="com.motionvault.panel" Version="2.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[14.0,99.9]" />
            <Host Name="AEFT" Version="[15.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.motionvault.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                        <Parameter>--high-dpi-support=1</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Motion Titles</Menu>
                    <Geometry>
                        <Size>
                            <Height>700</Height>
                            <Width>420</Width>
                        </Size>
                        <MinSize>
                            <Height>500</Height>
                            <Width>340</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2400</Height>
                            <Width>1200</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./img/icon-normal.png</Icon>
                        <Icon Type="RollOver">./img/icon-rollover.png</Icon>
                        <Icon Type="DarkNormal">./img/icon-dark.png</Icon>
                        <Icon Type="DarkRollOver">./img/icon-dark-rollover.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
