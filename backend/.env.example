# =================== SERVER ===================
PORT=8080
NODE_ENV=production
PUBLIC_URL=https://motionvault.app

# =================== DATABASE ===================
DATABASE_URL=postgres://motionvault:motionvault@localhost:5432/motionvault

# =================== SECURITY (JWT) ===================
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_bytes_hex
LICENSE_SECRET=change_me_64_bytes_hex
LICENSE_TTL_HOURS=24
TRIAL_DAYS=14

# =================== STRIPE ===================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Run tools/stripe-bootstrap.js to create products and fill these
STRIPE_PRICE_YEARLY=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx

# =================== CDN (optional) ===================
CDN_BASE=https://cdn.motionvault.app
CDN_SIGN_SECRET=cdn_random_hex
CDN_URL_TTL_MIN=60
