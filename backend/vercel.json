{
    "version": 2,
    "rewrites": [
        { "source": "/(.*)", "destination": "/src/server.js" }
    ],
    "functions": {
        "src/server.js": {
            "memory": 512,
            "maxDuration": 30
        }
    },
    "crons": [
        {
            "path": "/v1/cron/trial-reminders",
            "schedule": "0 14 * * *"
        }
    ]
}
