# Motion Suite · Tools credentials
#
# Copie este arquivo pra "tools/.env" e preencha com SUAS keys reais.
# O .env é gitignored — não vai pro GitHub.
#
# Onde achar cada key:
#   STRIPE_SECRET  → dashboard.stripe.com/apikeys (use Secret Key sk_live_... ou sk_test_...)
#   DATABASE_URL   → console.neon.tech → projeto motionpro → Connection Details → Direct connection
#   RESEND_API_KEY → resend.com/api-keys (opcional, só pra emails)
#   FAL_AI_KEY     → fal.ai/dashboard/keys (opcional, pra Seedance)

STRIPE_SECRET=sk_live_COLE_TUA_KEY_AQUI
DATABASE_URL=postgres://USER:PASS@HOST/db?sslmode=require
RESEND_API_KEY=re_xxx
FAL_AI_KEY=
