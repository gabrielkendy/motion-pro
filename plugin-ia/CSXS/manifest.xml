<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   ExtensionBundleId="com.motionpro.ia"
                   ExtensionBundleVersion="4.0.3"
                   ExtensionBundleName="Motion IA"
                   Version="5.0">
    <ExtensionList>
        <Extension Id="com.motionpro.ia" Version="4.0.3" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[14.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.motionpro.ia">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <!-- ScriptPath REMOVIDO (Agente α · 2026-05-21):
                         Confirmado via log forense CEP12-PPRO.log: o CEP/Premiere 26.x
                         tenta carregar host.jsx automaticamente no engine da extension
                         (com.motionpro.ia_Engine_Id) e FALHA com error code 27 do
                         PlugPlug. O engine ExtendScript fica INVÁLIDO permanentemente
                         pra essa extension — qualquer cs.evalScript subsequente (até
                         "1+1") retorna "EvalScript error." em ms.
                         Causa real do error 27 desconhecida (tamanho, race, encoding).
                         Fix: host.jsx é carregado SOMENTE em runtime via $.evalFile no
                         host-bridge.js, dentro do listener de AppOnline (engine vivo).
                         Ref: https://community.adobe.com/t5/after-effects/cep-hello-world-returns-quot-evalscript-error-quot/m-p/9366081 -->
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                        <Parameter>--high-dpi-support=1</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <!-- AutoVisible=false: painel só abre quando user clica em
                         Janela > Extensões > Motion IA. Evita janela flutuante
                         preta na frente do Premiere na primeira execução. -->
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Motion IA</Menu>
                    <Geometry>
                        <Size>
                            <Height>700</Height>
                            <Width>900</Width>
                        </Size>
                        <MinSize>
                            <Height>500</Height>
                            <Width>720</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2400</Height>
                            <Width>1200</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./img/icon.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
